{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/shared/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=604800" }]
    },
    {
      "source": "/pages/(.*).html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }
  ]
}
